# Copy this file to secrets.toml and fill in your values.
# secrets.toml is gitignored — never commit real credentials.

# Databricks — SQL Warehouse connection
# HOST:      your workspace URL, without https://
# TOKEN:     Settings → Developer → Access Tokens → Generate new token
# HTTP_PATH: SQL Warehouses → your warehouse → Connection Details tab → HTTP Path
DATABRICKS_HOST      = "dbc-xxxxxxxx-xxxx.cloud.databricks.com"
DATABRICKS_TOKEN     = "your-personal-access-token"
DATABRICKS_HTTP_PATH = "/sql/1.0/warehouses/<your-warehouse-id>"
DATABRICKS_CATALOG   = "vet_platform"
DATABRICKS_SCHEMA    = "gold"

# Bronze testing — set USE_BRONZE = "true" to read from bronze tables
# while the gold layer is not yet ready. Flip to "false" once gold exists.
# Set DATABRICKS_BRONZE_CATALOG and DATABRICKS_BRONZE_SCHEMA to wherever
# your DLT pipeline wrote the bronze entity tables.
USE_BRONZE                = "false"
DATABRICKS_BRONZE_CATALOG = "vet_platform"
DATABRICKS_BRONZE_SCHEMA  = "bronze"

#streamlit run app.py